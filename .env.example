# ---- Client (exposed to the browser, must start with VITE_) ----
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ---- Server only (set in Vercel project settings, NOT prefixed with VITE_) ----
# Any OpenAI-compatible provider. Examples:
#   Groq (free, fast):   https://api.groq.com/openai/v1   model: llama-3.3-70b-versatile
#   Gemini (free):       https://generativelanguage.googleapis.com/v1beta/openai   model: gemini-2.5-flash
#   OpenRouter:          https://openrouter.ai/api/v1      model: deepseek/deepseek-r1:free
#   DeepSeek:            https://api.deepseek.com           model: deepseek-chat
AI_BASE_URL=https://api.groq.com/openai/v1
AI_API_KEY=your-provider-key
AI_MODEL=llama-3.3-70b-versatile
